generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model EstimateRequest {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String
  address          String?
  service          String
  message          String?
  preferredContact String?
  status           String   @default("new")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}